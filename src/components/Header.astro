---
interface Props {
  activeNav?: string;
}
const { activeNav = '' } = Astro.props;

const navLinks = [
  { href: '/',        label: 'Home',      key: 'home' },
  { href: '/galerie', label: 'Galerie',   key: 'galerie' },
  { href: '/shop',    label: 'Shop',      key: 'shop' },
  { href: '/blog',    label: 'Blog',      key: 'blog' },
  { href: '/ueber',   label: 'Über mich', key: 'ueber' },
  { href: '/kontakt', label: 'Kontakt',   key: 'kontakt' },
];
---

<header id="site-header" class="sticky top-0 z-40">
  <div class="wood-panel border-b border-wood-400/40 shadow-[0_10px_30px_-20px_rgba(61,43,31,.55)]">
    <div class="max-w-6xl mx-auto px-5 md:px-8 h-[72px] md:h-[84px] flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Alita Ember — Startseite">
        <span class="logo-ring inline-flex items-center justify-center rounded-full overflow-hidden w-12 h-12 md:w-14 md:h-14">
          <img src="/images/logo.png" alt="" class="w-full h-full object-cover" />
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8 lg:gap-10 text-[17px] font-semibold text-char-800/85">
        {navLinks.map(link => (
          <a href={link.href} class={`nav-link${activeNav === link.key ? ' active' : ''}`}>
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Burger (theme/lang injected by JS after) -->
      <button id="burger" aria-label="Menü öffnen" aria-expanded="false"
              class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-full bg-wood-50/60 border border-wood-400/40 text-char-800">
        <svg id="burger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-500 ease-out">
      <nav class="px-5 pb-5 pt-1 flex flex-col gap-1 text-[17px] font-semibold">
        {navLinks.map(link => (
          <a href={link.href} class={`py-3 px-3 rounded-xl nav-link${activeNav === link.key ? ' active' : ''}`}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
