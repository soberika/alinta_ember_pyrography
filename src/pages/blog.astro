---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { langFromUrl, pick, dateLocale, PATHS, UI, POST_CATEGORY_LABELS } from '../lib/i18n';

// Sprache aus der Route (EN-Wrapper: src/pages/en/blog.astro)
const lang = langFromUrl(Astro.url);
const t = UI[lang];
const P = PATHS[lang];

const LABELS = POST_CATEGORY_LABELS[lang];

const posts = (await getCollection('posts'))
  .filter((p) => (p.data.status ?? 'public') === 'public')
  .sort((a, b) => {
    // Primär: order-Feld; Fallback: publishDate absteigend (neueste zuerst)
    if ((a.data.order ?? 999) !== (b.data.order ?? 999))
      return (a.data.order ?? 999) - (b.data.order ?? 999);
    return (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0);
  });

function formatDate(p: (typeof posts)[0]): string {
  if (p.data.publishDate)
    return p.data.publishDate.toLocaleDateString(dateLocale(lang), { day: 'numeric', month: 'long', year: 'numeric' });
  return p.data.date ?? '';
}

function estimateReadTime(body: any): string {
  if (!body || typeof body !== 'object') return '';
  function extractText(node: any): string {
    if (node.type === 'text') return node.text ?? '';
    return (node.children ?? []).map(extractText).join(' ');
  }
  const words = extractText(body).split(/\s+/).filter(Boolean).length;
  return words > 0 ? `${Math.max(1, Math.round(words / 200))} Min` : '';
}

const POSTS = posts.map((p) => ({
  slug: p.id,
  url: `${P.blog}/${p.id}`,
  cat: p.data.category,
  catLabel: LABELS[p.data.category] ?? p.data.category,
  date: formatDate(p),
  read: p.data.readTime || estimateReadTime(lang === 'en' && p.data.body_en ? p.data.body_en : p.data.body),
  title: pick(lang, p.data.title, p.data.title_en),
  excerpt: pick(lang, p.data.excerpt, p.data.excerpt_en),
  thumb: p.data.coverImage || p.data.thumbnail || 'illus:funke',
  tags: p.data.tags ?? [],
}));

// Hervorgehobener Beitrag für den Hero (Schalter „featured", sonst der erste)
const featuredEntry = posts.find((p) => p.data.featured) ?? posts[0];
const featured = featuredEntry
  ? {
      slug: featuredEntry.id,
      heading: pick(
        lang,
        featuredEntry.data.featuredHeading || featuredEntry.data.title,
        featuredEntry.data.featuredHeading_en || featuredEntry.data.title_en,
      ),
      excerpt: pick(
        lang,
        featuredEntry.data.featuredExcerpt || featuredEntry.data.excerpt || '',
        featuredEntry.data.featuredExcerpt_en || featuredEntry.data.excerpt_en,
      ),
      image: featuredEntry.data.featuredImage || '/assets/work-forest.png',
      date: formatDate(featuredEntry),
      read: featuredEntry.data.readTime || estimateReadTime(featuredEntry.data.body),
      highlights:
        lang === 'en' && (featuredEntry.data.highlights_en ?? []).length > 0
          ? featuredEntry.data.highlights_en
          : featuredEntry.data.highlights ?? [],
    }
  : null;
---

<Base title={t.meta.blogTitle} description={t.meta.blogDesc}>
  <Header active="blog" />

  <!-- HERO -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-6 md:pt-8">
      <div class="wood-bg relative rounded-[28px] overflow-hidden ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.45)]">
        <div id="embers" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
        <div class="hero-vignette"></div>
        <div class="relative px-6 md:px-12 lg:px-16 pt-14 md:pt-20 pb-12 md:pb-16">
          <p class="eyebrow">{t.blog.eyebrow}</p>
          <div class="mt-3">
            <h1 class="font-display font-extrabold text-char-900 leading-[.95] text-[44px] sm:text-[64px] md:text-[80px]">{t.blog.title}</h1>
            <p class="mt-5 text-[18px] md:text-[22px] text-char-800/90 leading-relaxed max-w-2xl">
              {t.blog.intro}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED POST -->
  {featured && (
    <section class="relative">
      <div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14">
        <div class="pin-card">
          <div class="bg"><img src={featured.image} alt="" /></div>
          <div class="relative grid md:grid-cols-12 gap-6 items-center px-6 md:px-12 py-10 md:py-14 text-wood-50">
            <div class="md:col-span-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="pcat" style="position:static;">{t.blog.featured}</span>
                <span class="text-[12px] tracking-[.18em] uppercase font-bold text-wood-200/80">{featured.date} · {featured.read} {t.blog.readTime}</span>
              </div>
              <h2 class="font-display font-extrabold leading-tight text-[30px] md:text-[44px]">{featured.heading}</h2>
              <p class="mt-4 text-[16px] md:text-[18px] text-wood-100/85 max-w-2xl">
                {featured.excerpt}
              </p>
              <div class="mt-7 flex flex-wrap gap-3">
                <a href={`${P.blog}/${featured.slug}`} class="btn btn-orange">{t.blog.readMore}</a>
                <a href={P.galerie} class="btn btn-yellow">{t.blog.workInGallery}</a>
              </div>
            </div>
            {featured.highlights.length > 0 && (
              <div class="md:col-span-4 hidden md:block">
                <div class="bg-black/30 backdrop-blur-sm border border-white/15 rounded-2xl p-5">
                  <p class="text-[11px] tracking-[.22em] uppercase font-bold text-ember-300">{t.blog.inThisPost}</p>
                  <ul class="mt-3 space-y-2 text-[14px] text-wood-100/90">
                    {featured.highlights.map((h, i) => (
                      <li class="flex gap-2"><span class="text-ember-300">{String(i + 1).padStart(2, '0')}</span><span>{h}</span></li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FILTERS + GRID -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-14 md:pt-20 pb-10">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
        <div>
          <p class="eyebrow">{t.blog.allPosts}</p>
          <h2 class="mt-2 font-display font-extrabold text-char-900 text-[28px] md:text-[40px]">{t.blog.storiesHeading}</h2>
        </div>
        <div class="flex flex-wrap gap-2" id="filters" role="tablist" aria-label={t.blog.filterLabel}>
          <button class="filter-chip active" data-filter="all">{t.blog.all}</button>
          <button class="filter-chip" data-filter="technik">{LABELS.technik}</button>
          <button class="filter-chip" data-filter="news">{LABELS.news}</button>
          <button class="filter-chip" data-filter="werkstatt">{LABELS.werkstatt}</button>
          <button class="filter-chip" data-filter="prozess">{LABELS.prozess}</button>
        </div>
      </div>

      <div id="posts" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-7"></div>
      <p id="empty-msg" class="hidden text-center text-char-800/70 py-16">{t.blog.empty}</p>

      <div class="mt-12 flex justify-center">
        <button id="load-more" class="btn btn-yellow">{t.blog.loadMore}</button>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-24 md:pb-32">
      <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-400/40 grid md:grid-cols-12 gap-8 items-center">
        <div class="md:col-span-7">
          <p class="eyebrow">{t.blog.newsletterEyebrow}</p>
          <h2 class="mt-3 font-display font-extrabold text-char-900 text-[28px] md:text-[40px] leading-tight">{t.blog.newsletterHeading}</h2>
          <p class="mt-3 text-char-800/85 max-w-xl">{t.blog.newsletterText}</p>
        </div>
        <form class="md:col-span-5 flex flex-col gap-3" onsubmit={`event.preventDefault(); const b=this.querySelector('button'); b.textContent='${t.blog.subscribed}'; b.disabled=true; this.querySelector('input').value='';`}>
          <div class="flex gap-2">
            <input type="email" required placeholder={t.blog.newsletterPlaceholder} class="sub-input" aria-label={t.blog.newsletterAria} />
            <button type="submit" class="btn btn-orange whitespace-nowrap">{t.blog.subscribe}</button>
          </div>
          <p class="text-xs text-char-800/60">{t.blog.newsletterConsent}</p>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <style is:global>
    .post-card{ background:rgba(255,250,242,.6); border:1px solid rgba(120,82,44,.18); border-radius:22px; overflow:hidden; transition:transform .35s ease, box-shadow .35s ease, border-color .35s ease; display:flex; flex-direction:column; }
    .post-card:hover{ transform:translateY(-6px); border-color:rgba(232,93,4,.55); box-shadow:0 24px 60px -28px rgba(232,93,4,.45), 0 0 0 1px rgba(232,93,4,.25); }
    .post-card .thumb{ aspect-ratio: 16/10; position:relative; overflow:hidden; }
    .post-card .thumb::after{ content:""; position:absolute; inset:0; background:linear-gradient(180deg, transparent 40%, rgba(0,0,0,.35)); }
    .post-card .thumb img{ width:100%; height:100%; object-fit:cover; transition:transform .8s ease; }
    .post-card:hover .thumb img{ transform:scale(1.05); }
    .pcat{ position:absolute; left:14px; top:14px; z-index:2; background:rgba(232,93,4,.92); color:#fff8e7; font-size:11px; font-weight:800; letter-spacing:.18em; text-transform:uppercase; padding:6px 10px; border-radius:999px; box-shadow:0 6px 16px -8px rgba(232,93,4,.7); }
    .pmeta{ font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:rgba(61,43,31,.6); font-weight:700; }
    html.dark .post-card{ background:rgba(40,28,18,.55); border-color:rgba(120,82,44,.45); }
    html.dark .pmeta{ color:rgba(245,232,199,.55); }

    .pin-card{ position:relative; border-radius:28px; overflow:hidden; border:1px solid rgba(120,82,44,.25); box-shadow:0 40px 80px -40px rgba(61,43,31,.55); background:#1a1108; isolation:isolate; }
    .pin-card .bg{ position:absolute; inset:0; }
    .pin-card .bg img{ width:100%; height:100%; object-fit:cover; opacity:.55; }
    .pin-card .bg::after{ content:""; position:absolute; inset:0; background:linear-gradient(115deg, rgba(20,12,6,.85) 30%, rgba(20,12,6,.35) 70%, rgba(20,12,6,.1)); }
    .filter-chip{ padding:8px 16px; border-radius:999px; border:1px solid rgba(120,82,44,.35); background:rgba(255,250,242,.55); color:#3d2b1f; font-weight:700; font-size:14px; transition:all .25s ease; cursor:pointer; }
    .filter-chip:hover{ border-color:rgba(232,93,4,.6); color:#e85d04; }
    .filter-chip.active{ background:linear-gradient(180deg,#ff7a1a,#e85d04); color:#fff8e7; border-color:transparent; box-shadow:0 10px 24px -10px rgba(232,93,4,.7); }
    html.dark .filter-chip{ background:rgba(40,28,18,.55); color:#f5e8c7; border-color:rgba(120,82,44,.55); }

    .illus{ width:100%; height:100%; display:block; }

    .sub-input{ flex:1; min-width:0; background:rgba(255,255,255,.7); border:1px solid rgba(120,82,44,.3); padding:14px 16px; border-radius:14px; font-size:15px; color:#3d2b1f; outline:none; transition:border-color .25s ease, box-shadow .25s ease; }
    .sub-input:focus{ border-color:#e85d04; box-shadow:0 0 0 4px rgba(232,93,4,.18); }
    html.dark .sub-input{ background:rgba(20,12,6,.55); color:#f5e8c7; border-color:rgba(120,82,44,.5); }
  </style>

  <script define:vars={{ POSTS, LABELS, L: { readMore: t.blog.readMore } }}>
    // SVG thumbnail factory — different motifs per post
    function svgThumb(kind){
      const base = (inner, bg='#1a0f06', accent='#ff7a1a') => `
        <svg class="illus" viewBox="0 0 400 250" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="g${kind}" cx="50%" cy="60%" r="65%">
              <stop offset="0%" stop-color="${accent}" stop-opacity=".55"/>
              <stop offset="60%" stop-color="${accent}" stop-opacity=".05"/>
              <stop offset="100%" stop-color="${bg}" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <rect width="400" height="250" fill="${bg}"/>
          <rect width="400" height="250" fill="url(#g${kind})"/>
          ${inner}
        </svg>`;
      const motifs = {
        spitzen: base(`
          <g stroke="#ffb070" stroke-width="2" fill="none" opacity=".85">
            <path d="M40 200 L80 110 L120 200"/>
            <path d="M120 200 L160 80 L200 200"/>
            <path d="M200 200 L240 130 L280 200"/>
            <path d="M280 200 L320 100 L360 200"/>
          </g>
          <circle cx="80" cy="108" r="4" fill="#ff7a1a"/>
          <circle cx="160" cy="78" r="5" fill="#ff7a1a"/>
          <circle cx="240" cy="128" r="4" fill="#ff7a1a"/>
          <circle cx="320" cy="98" r="5" fill="#ff7a1a"/>`),
        holz: base(`
          <g stroke="#c98a4b" stroke-width="1.5" fill="none" opacity=".7">
            ${Array.from({length:14},(_,i)=>`<path d="M0 ${30+i*16} Q200 ${20+i*16} 400 ${35+i*16}"/>`).join('')}
          </g>
          <ellipse cx="200" cy="125" rx="60" ry="35" fill="none" stroke="#ff9f1c" stroke-width="2.5"/>
          <ellipse cx="200" cy="125" rx="35" ry="20" fill="none" stroke="#ff9f1c" stroke-width="2"/>
          <ellipse cx="200" cy="125" rx="15" ry="9" fill="#ff7a1a" opacity=".6"/>`),
        edition: base(`
          <g fill="none" stroke="#ff9f1c" stroke-width="2.5">
            <circle cx="150" cy="125" r="55"/>
            <circle cx="250" cy="125" r="55"/>
          </g>
          <text x="150" y="138" text-anchor="middle" font-family="Georgia" font-size="36" fill="#ff7a1a" font-weight="bold">01</text>
          <text x="250" y="138" text-anchor="middle" font-family="Georgia" font-size="36" fill="#ff7a1a" font-weight="bold">24</text>`,'#1a0f06','#e85d04'),
        studio: base(`
          <rect x="60" y="80" width="280" height="120" fill="none" stroke="#c98a4b" stroke-width="2"/>
          <rect x="60" y="80" width="280" height="20" fill="#3d2b1f" opacity=".6"/>
          <rect x="90" y="120" width="80" height="60" fill="#ff7a1a" opacity=".2" stroke="#ff9f1c" stroke-width="1.5"/>
          <rect x="200" y="120" width="120" height="60" fill="#ff7a1a" opacity=".15" stroke="#ff9f1c" stroke-width="1.5"/>
          <circle cx="320" cy="60" r="20" fill="#ff9f1c" opacity=".4"/>
          <circle cx="320" cy="60" r="10" fill="#ff7a1a"/>`),
        skizze: base(`
          <g stroke="#ffb070" stroke-width="1.2" fill="none" opacity=".7">
            <path d="M80 170 Q120 80 200 100 T320 170"/>
            <path d="M70 180 Q130 90 200 110 T330 180"/>
          </g>
          <g stroke="#ff7a1a" stroke-width="2" fill="none">
            <path d="M150 130 Q175 100 200 130 Q225 160 250 130"/>
            <circle cx="200" cy="130" r="4" fill="#ff7a1a"/>
          </g>`),
        funke: base(`
          <g fill="#ff9f1c">
            ${Array.from({length:60},()=>{
              const x=Math.floor(Math.random()*400), y=Math.floor(Math.random()*250), r=1+Math.random()*2.5;
              return `<circle cx="${x}" cy="${y}" r="${r.toFixed(1)}" opacity="${(.3+Math.random()*.6).toFixed(2)}"/>`;
            }).join('')}
          </g>
          <path d="M180 125 Q200 90 220 125 Q200 160 180 125 Z" fill="#ff7a1a" opacity=".75"/>
          <path d="M195 110 Q200 95 205 110 Q200 130 195 110 Z" fill="#ffe7a0"/>`),
        klang: base(`
          <g stroke="#ff9f1c" stroke-width="2" fill="none">
            <circle cx="200" cy="125" r="30"/>
            <circle cx="200" cy="125" r="55" opacity=".7"/>
            <circle cx="200" cy="125" r="80" opacity=".4"/>
            <circle cx="200" cy="125" r="105" opacity=".2"/>
          </g>
          <circle cx="200" cy="125" r="8" fill="#ff7a1a"/>`),
        zahn: base(`
          <g fill="none" stroke="#ff9f1c" stroke-width="2">
            <circle cx="140" cy="125" r="45"/>
            <circle cx="260" cy="125" r="35"/>
          </g>
          <g stroke="#ff7a1a" stroke-width="3">
            ${Array.from({length:12},(_,i)=>{ const a=i*30*Math.PI/180; const x1=140+45*Math.cos(a), y1=125+45*Math.sin(a); const x2=140+55*Math.cos(a), y2=125+55*Math.sin(a); return `<line x1="${x1.toFixed(1)}" y1="${y1.toFixed(1)}" x2="${x2.toFixed(1)}" y2="${y2.toFixed(1)}"/>`; }).join('')}
          </g>
          <circle cx="140" cy="125" r="10" fill="#ff7a1a"/>
          <circle cx="260" cy="125" r="8" fill="#ff9f1c"/>`)
      };
      return motifs[kind] || motifs.spitzen;
    }

    const PAGE = 6;
    let shown = PAGE;
    let filter = 'all';

    const grid = document.getElementById('posts');
    const empty = document.getElementById('empty-msg');
    const loadBtn = document.getElementById('load-more');

    function thumbHtml(t){
      if (t.startsWith('illus:')) return svgThumb(t.slice(6));
      return `<img src="${t}" alt="" loading="lazy" decoding="async" />`;
    }

    function render(){
      const list = POSTS.filter(p => filter === 'all' || p.cat === filter);
      const slice = list.slice(0, shown);
      grid.innerHTML = slice.map(p => `
        <a href="${p.url}" class="post-card">
          <div class="thumb"><span class="pcat">${p.catLabel}</span>${thumbHtml(p.thumb)}</div>
          <div class="p-6 flex-1 flex flex-col">
            <div class="pmeta">${p.date}${p.read ? ' · ' + p.read : ''}</div>
            <h3 class="mt-3 font-display font-bold text-char-900 text-[20px] leading-snug">${p.title}</h3>
            <p class="mt-2 text-[15px] text-char-800/80 leading-relaxed">${p.excerpt}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-ember-700 font-bold text-sm">${L.readMore}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      `).join('');
      empty.classList.toggle('hidden', list.length > 0);
      loadBtn.style.display = (slice.length < list.length) ? '' : 'none';
    }

    document.getElementById('filters').addEventListener('click', e => {
      const b = e.target.closest('[data-filter]'); if (!b) return;
      document.querySelectorAll('#filters .filter-chip').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      filter = b.dataset.filter;
      shown = PAGE;
      render();
    });
    loadBtn.addEventListener('click', () => { shown += PAGE; render(); });

    render();
    document.getElementById('yr').textContent = new Date().getFullYear();
  </script>
</Base>
