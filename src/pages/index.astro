---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { formatDimensions } from '../lib/works';
import { langFromUrl, localizedSingleton, pick, PATHS, UI } from '../lib/i18n';

// Sprache aus der Route: diese Seite wird auch von src/pages/en/index.astro
// als Komponente gerendert und erkennt EN dann an der URL (/en/).
const lang = langFromUrl(Astro.url);
const t = UI[lang];
const P = PATHS[lang];

const home = localizedSingleton(await getCollection('home'), lang).data;

// Featured-Werke = die ersten 4 aus der Werke-Collection.
// 'order' wirkt als Pin (kleiner = weiter vorne), sonst chronologisch (neueste zuerst).
const works = (await getCollection('works'))
  .filter((w) => (w.data.status ?? 'public') === 'public')
  .sort((a, b) => {
    const oa = a.data.order ?? 999;
    const ob = b.data.order ?? 999;
    if (oa !== ob) return oa - ob;
    const da = a.data.date ? a.data.date.getTime() : 0;
    const db = b.data.date ? b.data.date.getTime() : 0;
    return db - da;
  })
  .slice(0, 4);

const WORKS = works.map((w) => ({
  id: w.id,
  title: pick(lang, w.data.title, w.data.title_en),
  img: w.data.image,
  eyebrow: pick(lang, w.data.eyebrow, w.data.eyebrow_en),
  desc: pick(lang, w.data.description, w.data.description_en),
  year: w.data.date ? String(w.data.date.getFullYear()) : '',
  dims: formatDimensions(w.data.dimensions),
  tags: (w.data.tags ?? []).filter(Boolean),
  etsy: w.data.etsyUrl ?? '',
  meta: (w.data.meta ?? []).map((m) => [m.label, m.value]),
}));

// Redirect-Ziel nach Formular-Versand (zurück auf diese Seite, richtige Sprache)
const FORM_NEXT = new URL(`${P.home}?gesendet=1#kontakt`, Astro.site ?? 'https://www.alinta-ember.com').toString();
---

<Base title={t.meta.homeTitle} description={t.meta.homeDesc}>
  <Header active="home" />

  <!-- ============== HERO ============== -->
  <section id="home" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-6 md:pt-8">
      <div class="relative rounded-[28px] overflow-hidden ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.45)]">
        <img src="/assets/Alinta-Ember-Banner.png"
             alt={t.home.heroAlt}
             class="absolute inset-0 w-full h-full object-cover object-left select-none pointer-events-none"
             draggable="false" />
        <div class="absolute inset-0 pointer-events-none"
             style="background: linear-gradient(90deg, rgba(26,17,8,.04) 0%, rgba(26,17,8,.22) 40%, rgba(26,17,8,.70) 72%, rgba(26,17,8,.90) 100%);"></div>
        <div class="absolute inset-0 pointer-events-none"
             style="background: linear-gradient(0deg, rgba(26,17,8,.55) 0%, transparent 42%);"></div>
        <div id="embers" class="absolute inset-0 pointer-events-none overflow-hidden"></div>

        <div class="relative grid md:grid-cols-12 gap-6 items-center px-6 md:px-12 lg:px-16 pt-14 md:pt-20 pb-10 md:pb-16 min-h-[560px] md:min-h-[640px]">
          <div class="md:col-span-6 md:col-start-7 relative z-10 text-right md:text-left">
            <h1 class="font-display font-extrabold tracking-tight text-wood-50 leading-[.95]
                       text-[64px] sm:text-[84px] md:text-[92px] lg:text-[108px]"
                style="text-shadow: 0 6px 32px rgba(0,0,0,.6), 0 1px 2px rgba(0,0,0,.65);">
              Alinta<br class="hidden sm:block" /><span class="sm:hidden"> </span>Ember
            </h1>
            <p class="mt-5 md:mt-7 text-[22px] md:text-[26px] lg:text-[28px] leading-snug text-wood-100 max-w-[18ch] ml-auto md:ml-0"
               style="text-shadow: 0 2px 16px rgba(0,0,0,.7);">
              {home.heroSubtitle}
            </p>
            <div class="mt-8 md:mt-10 flex flex-wrap gap-4 justify-end md:justify-start">
              <a href={P.galerie} class="btn btn-orange">{home.heroCta1 ?? t.home.fullGallery}</a>
              <a href={P.shop} class="btn btn-yellow">{home.heroCta2 ?? t.home.fullShop}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== FEATURED WORKS (overview → /galerie) ============== -->
  <section id="galerie" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-12 md:pt-16 pb-12 md:pb-16">
      <div class="cream-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 shadow-[0_20px_50px_-30px_rgba(61,43,31,.35)] ring-1 ring-wood-300/60">

        <header class="text-center mb-10 md:mb-14">
          <p class="eyebrow">{home.featuredEyebrow}</p>
          <h2 class="mt-3 font-display font-extrabold text-char-900 text-[40px] sm:text-[52px] md:text-[60px] leading-tight">
            {home.featuredHeading}
          </h2>
          <p class="mt-4 text-char-800/80 max-w-xl mx-auto text-[16px] md:text-[17px]">
            {home.featuredIntro}
          </p>
        </header>

        <div id="works-grid" class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6"></div>

        <div class="mt-12 md:mt-14 flex flex-col sm:flex-row gap-4 items-center justify-center">
          <a href={P.galerie} class="btn btn-orange">
            {t.home.fullGallery}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={`${P.galerie}#filter`} class="arrow-link">{t.home.filterByCategory}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== ABOUT (overview → /ueber) ============== -->
  <section id="ueber" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-12 md:pb-16">
      <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-14 md:py-20 ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.4)] grid md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7">
          <p class="eyebrow">{home.aboutEyebrow}</p>
          <h2 class="mt-3 font-display font-extrabold text-char-900 text-[36px] md:text-[48px] leading-tight">
            {home.aboutHeading}
          </h2>
          <p class="mt-5 text-[17px] md:text-[18px] leading-relaxed text-char-800/90 max-w-2xl">
            {home.aboutText}
          </p>
          <div class="mt-7 flex flex-wrap gap-4">
            <a href={P.ueber} class="btn btn-orange">
              {t.home.myStory}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={`${P.ueber}#prozess`} class="arrow-link">{t.home.myProcess}</a>
          </div>
        </div>
        <div class="md:col-span-5">
          <div class="relative">
            <div class="absolute -inset-4 rounded-full blur-2xl opacity-80"
                 style="background: radial-gradient(closest-side, rgba(255,150,40,.45), transparent 70%);"></div>
            <img src="/assets/logo.png" alt="" class="relative w-44 h-44 md:w-56 md:h-56 rounded-full object-cover ring-1 ring-wood-400/60 mx-auto shadow-ember-glow" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== SHOP (overview → /shop) ============== -->
  <section id="shop" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-12 md:pb-16">
      <div class="cream-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-14 md:py-20 ring-1 ring-wood-300/60 text-center">
        <p class="eyebrow">{home.shopEyebrow}</p>
        <h2 class="mt-3 font-display font-extrabold text-char-900 text-[36px] md:text-[48px] leading-tight">
          {home.shopHeading}
        </h2>
        <p class="mt-4 text-char-800/80 max-w-xl mx-auto text-[16px] md:text-[17px]">
          {home.shopIntro}
        </p>

        <div class="mt-10 grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto text-left">
          {home.shopCards.map((c) => (
            <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/30 p-5">
              <div class="font-display font-bold text-char-900 text-2xl">{c.title}</div>
              <p class="mt-1 text-sm text-char-800/80">{c.text}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href={P.shop} class="btn btn-yellow">
            {t.home.fullShop}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={`${P.kontakt}#auftrag`} class="arrow-link">{t.home.requestCommission}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== CONTACT (overview → /kontakt) ============== -->
  <section id="kontakt" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-24 md:pb-32">
      <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-400/40 grid md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="eyebrow">{home.contactEyebrow}</p>
          <h2 class="mt-3 font-display font-extrabold text-char-900 text-[32px] md:text-[42px] leading-tight">
            {home.contactHeading}
          </h2>
          <p class="mt-4 text-char-800/85 text-[16px] md:text-[17px] leading-relaxed max-w-md">
            {home.contactText}
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a href={P.kontakt} class="btn btn-orange">
              {t.home.toContactPage}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={`${P.kontakt}#auftrag`} class="arrow-link">{t.home.commission}</a>
          </div>
        </div>
        <form class="grid gap-3" action="https://formsubmit.co/admin@alinta-ember.com" method="POST">
          <input type="hidden" name="_subject" value={t.home.formSubject} />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value={FORM_NEXT} />
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
          <input required type="text"  name="name"      placeholder={t.home.formName}    class="field" />
          <input required type="email" name="email"     placeholder={t.home.formEmail}   class="field" />
          <textarea required rows="3"  name="nachricht" placeholder={t.home.formMessage} class="field"></textarea>
          <div class="flex flex-wrap gap-3 items-center">
            <button class="btn btn-orange">{t.home.formSend}</button>
            <span id="mini-thanks" class="hidden text-sm text-ember-700 font-semibold">{t.home.formThanks}</span>
          </div>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <!-- ============== MODAL ============== -->
  <div id="modal" class="fixed inset-0 z-[60] hidden overflow-y-auto">
    <div id="modal-backdrop" class="fixed inset-0 modal-backdrop"></div>
    <button id="modal-close" aria-label={t.modal.close}
            class="fixed top-4 right-4 md:top-6 md:right-6 z-[70] w-10 h-10 rounded-full bg-black/40 hover:bg-black/60 text-white grid place-items-center backdrop-blur">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
    <div id="modal-scroll" class="relative min-h-full flex items-center justify-center p-4 md:p-8">
      <div id="modal-card" class="relative modal-pop w-full max-w-3xl rounded-3xl overflow-hidden shadow-ember-glow-lg ring-1 ring-ember-500/40 bg-wood-100">
        <div class="grid md:grid-cols-2">
          <div class="bg-wood-200 p-6 md:p-8 grid place-items-center">
            <div class="relative w-full aspect-[3/4] max-w-[360px]">
              <div class="absolute -inset-4 rounded-3xl blur-2xl opacity-80"
                   style="background: radial-gradient(closest-side, rgba(255,140,30,.45), transparent 70%);"></div>
              <img id="modal-img" alt="" class="relative w-full h-full object-cover rounded-2xl ring-1 ring-wood-400/50" />
            </div>
          </div>
          <div class="p-7 md:p-10 wood-panel">
            <p class="eyebrow" id="modal-eyebrow">{t.modal.work}</p>
            <h3 id="modal-title" class="mt-2 font-display font-extrabold text-char-900 text-3xl md:text-4xl leading-tight">Titel</h3>
            <p id="modal-desc"  class="mt-4 text-char-800/90 text-[16px] leading-relaxed whitespace-pre-line"></p>
            <ul id="modal-meta" class="mt-6 grid grid-cols-2 gap-3 text-[14px] text-char-800/80"></ul>
            <div id="modal-tags" class="mt-5 flex flex-wrap gap-2"></div>
            <div class="mt-8 flex flex-wrap gap-3">
              <a id="modal-etsy-link" href="#" target="_blank" rel="noopener" class="btn btn-yellow hidden">{t.modal.buyOnEtsy}</a>
              <a id="modal-commission-link" href={`${P.kontakt}#auftrag`} class="btn btn-orange">{t.modal.requestEdition}</a>
              <button id="modal-close-2" class="btn btn-yellow">{t.modal.close}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ WORKS, L: { openDetails: t.modal.openDetails, view: t.modal.view, year: t.modal.year, dims: t.modal.dims, tagTitle: t.modal.tagLinkTitle }, PK: P.kontakt, PG: P.galerie }}>
    (function(){
      const grid = document.getElementById('works-grid');
      grid.innerHTML = WORKS.map(w => `
        <button class="work-card group relative text-left focus:outline-none focus:ring-2 focus:ring-ember-500/60 rounded-2xl h-full flex flex-col" data-id="${w.id}" aria-label="${w.title} — ${L.openDetails}">
          <span class="work-card-glow"></span>
          <div class="work-card-frame p-3 md:p-4 h-full flex flex-col">
            <div class="aspect-[3/4] overflow-hidden rounded-xl bg-wood-300 relative">
              <img src="${w.img}" alt="${w.title}" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
              <span class="absolute bottom-2 right-2 inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-ember-600/90 text-white text-xs font-semibold opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 backdrop-blur-sm shadow-lg">
                ${L.view}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
            <div class="mt-3 md:mt-4 flex-1">
              <span class="font-display font-bold text-char-900 text-[16px] md:text-[18px] leading-tight line-clamp-2">${w.title}</span>
            </div>
          </div>
        </button>
      `).join('');
      grid.querySelectorAll('.work-card').forEach(btn => {
        btn.addEventListener('click', () => openModal(btn.dataset.id));
      });
    })();

    const modal = document.getElementById('modal');
    const backdrop = document.getElementById('modal-backdrop');
    function openModal(id){
      const w = WORKS.find(x => x.id === id);
      if (!w) return;
      document.getElementById('modal-img').src = w.img;
      document.getElementById('modal-img').alt = w.title;
      document.getElementById('modal-eyebrow').textContent = w.eyebrow;
      document.getElementById('modal-title').textContent = w.title;
      document.getElementById('modal-desc').textContent  = w.desc;
      document.getElementById('modal-commission-link').href =
        PK + '?werk=' + encodeURIComponent(w.title) + '#auftrag';
      const etsyLink = document.getElementById('modal-etsy-link');
      etsyLink.href = w.etsy || '#';
      etsyLink.classList.toggle('hidden', !w.etsy);
      const tile = (k, v) => `
        <li class="rounded-xl bg-white/55 border border-wood-400/40 px-3 py-2">
          <span class="block text-[11px] uppercase tracking-[.18em] text-ember-700 font-semibold">${k}</span>
          <span class="block mt-0.5 font-medium">${v}</span>
        </li>`;
      const yearTile = w.year ? tile(L.year, w.year) : '';
      const dimsTile = w.dims ? tile(L.dims, w.dims) : '';
      document.getElementById('modal-meta').innerHTML =
        yearTile + dimsTile + w.meta.map(([k,v]) => tile(k, v)).join('');

      const tagsEl = document.getElementById('modal-tags');
      tagsEl.innerHTML = (w.tags || [])
        .map(t => `<a class="tag-btn" href="${PG}?tag=${encodeURIComponent(t)}" title="${L.tagTitle.replace('{tag}', t)}">#${t}</a>`)
        .join('');
      tagsEl.classList.toggle('hidden', !(w.tags && w.tags.length));
      modal.classList.remove('hidden');
      modal.scrollTop = 0;
      document.body.style.overflow = 'hidden';
    }
    function closeModal(){
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-close-2').addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    // Der Scroll-Wrapper liegt über dem Backdrop — Klick auf die freie Fläche
    // neben der Karte muss das Modal ebenfalls schließen.
    const scrollWrap = document.getElementById('modal-scroll');
    scrollWrap.addEventListener('click', (e) => { if (e.target === scrollWrap) closeModal(); });
    window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // Erfolgsmeldung nach Formular-Versand (?gesendet=1, Redirect von FormSubmit)
    if (new URLSearchParams(location.search).get('gesendet')) {
      const t = document.getElementById('mini-thanks');
      if (t) t.classList.remove('hidden');
    }
  </script>
</Base>
