---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { langFromUrl, localizedSingleton, PATHS, UI } from '../lib/i18n';

// Sprache aus der Route (EN-Wrapper: src/pages/en/about.astro)
const lang = langFromUrl(Astro.url);
const t = UI[lang];
const P = PATHS[lang];

const about = localizedSingleton(await getCollection('about'), lang).data;
---

<Base title={t.meta.ueberTitle} description={t.meta.ueberDesc}>
  <Header active="ueber" />

  <!-- HERO -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-6 md:pt-8">
      <div class="wood-bg relative rounded-[28px] overflow-hidden ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.45)]">
        <div id="embers" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
        <div class="hero-vignette"></div>
        <div class="relative grid md:grid-cols-12 gap-6 items-center px-6 md:px-12 lg:px-16 pt-14 md:pt-20 pb-10 md:pb-16">
          <div class="md:col-span-7">
            <p class="eyebrow">{about.heroEyebrow}</p>
            <h1 class="mt-3 font-display font-extrabold text-char-900 leading-[.95] text-[44px] sm:text-[64px] md:text-[80px]">{about.heroTitle}</h1>
            <p class="mt-5 text-[18px] md:text-[22px] text-char-800/90 leading-relaxed max-w-2xl">
              {about.heroIntro}
            </p>
          </div>
          <div class="md:col-span-5">
            <div class="relative max-w-[360px] mx-auto">
              <div class="absolute -inset-6 rounded-full blur-3xl opacity-90" style="background: radial-gradient(closest-side, rgba(255,150,40,.55), transparent 75%);"></div>
              <img src="/assets/alinta-character.png" alt="Alinta Ember" class="relative hero-character float-slow w-full" draggable="false" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STORY -->
  <section class="relative">
    <div class="max-w-3xl mx-auto px-5 md:px-8 pt-14 md:pt-20 pb-8">
      <p class="eyebrow text-center">{t.about.storyEyebrow}</p>
      <h2 class="mt-3 font-display font-extrabold text-char-900 text-center text-[32px] md:text-[44px] leading-tight">{about.storyHeading}</h2>
      <div class="prose-like mt-8 space-y-5 text-[17px] md:text-[18px] text-char-800/90 leading-relaxed">
        {about.storyParagraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- PROZESS -->
  <section id="prozess" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-16 pb-12 md:pb-20">
      <div class="cream-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-300/60">
        <div class="text-center max-w-2xl mx-auto">
          <p class="eyebrow">{about.processEyebrow}</p>
          <h2 class="mt-3 font-display font-extrabold text-char-900 text-[32px] md:text-[44px]">{about.processHeading}</h2>
          <p class="mt-3 text-char-800/80">{about.processIntro}</p>
        </div>
        <ol class="mt-10 grid md:grid-cols-4 gap-5">
          {about.processSteps.map((step, i) => (
            <li class="rounded-2xl bg-white/55 ring-1 ring-wood-400/40 p-6">
              <div class="font-display font-extrabold text-ember-700 text-5xl">{i + 1}</div>
              <h3 class="mt-2 font-display font-bold text-char-900 text-xl">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-char-800/85">{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- MATERIAL / WERKZEUG -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-12 md:pb-20 grid md:grid-cols-2 gap-6">
      <div class="wood-panel rounded-[28px] ring-1 ring-wood-400/40 p-8 md:p-10">
        <p class="eyebrow">{about.materialEyebrow}</p>
        <h3 class="mt-2 font-display font-bold text-char-900 text-2xl md:text-3xl">{about.materialHeading}</h3>
        <p class="mt-3 text-char-800/85 leading-relaxed">{about.materialText}</p>
      </div>
      <div class="wood-panel rounded-[28px] ring-1 ring-wood-400/40 p-8 md:p-10">
        <p class="eyebrow">{about.toolsEyebrow}</p>
        <h3 class="mt-2 font-display font-bold text-char-900 text-2xl md:text-3xl">{about.toolsHeading}</h3>
        <p class="mt-3 text-char-800/85 leading-relaxed">{about.toolsText}</p>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="relative">
    <div class="max-w-3xl mx-auto px-5 md:px-8 pb-16 md:pb-24">
      <p class="eyebrow text-center">{t.about.timelineEyebrow}</p>
      <h2 class="mt-2 text-center font-display font-extrabold text-char-900 text-[28px] md:text-[36px]">{about.timelineHeading}</h2>
      <ul class="mt-8 space-y-4">
        {about.timeline.map((t) => (
          <li class="grid grid-cols-[80px_1fr] gap-4 items-start">
            <div class="font-display font-bold text-ember-700 text-xl">{t.year}</div>
            <div><div class="font-bold text-char-900">{t.title}</div><div class="text-char-800/80 text-sm">{t.subtitle}</div></div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-24 md:pb-32">
      <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-400/40 text-center">
        <h2 class="font-display font-extrabold text-char-900 text-[28px] md:text-[40px]">{about.ctaHeading}</h2>
        <p class="mt-3 text-char-800/85 max-w-xl mx-auto">{about.ctaText}</p>
        <div class="mt-7 flex flex-wrap gap-4 justify-center">
          <a href={P.kontakt} class="btn btn-orange">{t.about.getInTouch}</a>
          <a href={P.galerie} class="btn btn-yellow">{t.about.viewWorks}</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
