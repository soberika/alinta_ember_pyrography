---
import BaseLayout from '../layouts/BaseLayout.astro';

const process = [
  {
    num: '01',
    title: 'Skizze',
    desc: 'Konzept, Komposition, Lichtführung. Vorzeichnung in mehreren Iterationen.',
  },
  {
    num: '02',
    title: 'Holzauswahl',
    desc: 'Birke, Eiche, Linde — Maserung muss zum Motiv passen. Geschliffen, geölt, bereit.',
  },
  {
    num: '03',
    title: 'Brennen',
    desc: 'Konturen zuerst, dann Schicht für Schicht Tiefe. 15–80 Stunden je nach Größe.',
  },
  {
    num: '04',
    title: 'Finish',
    desc: 'Akzent-Lasur, Versiegelung mit Naturöl, Signatur. Versand-bereit verpackt.',
  },
];

const milestones = [
  { year: '2019', title: 'Erste Ausstellung', sub: 'Kleine Galerie · Freiburg' },
  { year: '2021', title: 'Werkstatteröffnung', sub: 'Eigene Werkstatt am Waldrand' },
  { year: '2022', title: 'Steampunk-Reihe', sub: 'Erste Serien-Edition · 24 Stücke' },
  { year: '2024', title: 'Selbstporträt-Serie', sub: 'Laufend · individuelle Aufträge willkommen' },
];
---

<BaseLayout
  title="Über mich — Alita Ember Pyrography"
  description="Ich bin Alita — Pyrographie-Künstlerin aus Süddeutschland. Ich brenne Geschichten in Holz — von feurigen Phönixen bis zu schweigenden Uhrwerken."
  activeNav="ueber"
>

<div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-24 md:pb-32">

  <!-- Hero section -->
  <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-14 md:py-20 ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.4)] grid md:grid-cols-12 gap-10 items-center mb-10">
    <div class="md:col-span-7">
      <p class="eyebrow">Über mich</p>
      <h1 class="mt-3 font-display font-extrabold text-char-900 text-[40px] md:text-[56px] lg:text-[64px] leading-tight">
        Hallo, ich bin Alita.
      </h1>
      <p class="mt-5 text-[17px] md:text-[18px] leading-relaxed text-char-800/90">
        Pyrographie-Künstlerin aus Süddeutschland. Ich brenne Geschichten in Holz — von feurigen Phönixen bis zu schweigenden Uhrwerken.
      </p>
      <p class="mt-4 text-[17px] md:text-[18px] leading-relaxed text-char-800/80">
        Jedes Stück entsteht in stundenlanger Handarbeit, Linie für Linie, Funke für Funke. Holz, Hitze, Atem — das ist meine Sprache.
      </p>
      <div class="mt-7 flex flex-wrap gap-4">
        <a href="/galerie" class="btn btn-orange">Werke ansehen</a>
        <a href="/kontakt" class="arrow-link">Kontakt aufnehmen</a>
      </div>
    </div>
    <div class="md:col-span-5">
      <div class="relative">
        <div class="absolute -inset-4 rounded-full blur-2xl opacity-80"
             style="background: radial-gradient(closest-side, rgba(255,150,40,.45), transparent 70%);"></div>
        <img
          src="/images/logo.png"
          alt="Alita Ember"
          class="relative w-44 h-44 md:w-64 md:h-64 rounded-full object-cover ring-1 ring-wood-400/60 mx-auto shadow-ember-glow"
          loading="lazy"
        />
      </div>
    </div>
  </div>

  <!-- Process -->
  <div id="prozess" class="cream-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-300/60 mb-10">
    <div class="text-center mb-10">
      <p class="eyebrow">Prozess</p>
      <h2 class="mt-3 font-display font-extrabold text-char-900 text-[32px] md:text-[44px] leading-tight">
        Vom ersten Funken bis zum letzten Strich.
      </h2>
      <p class="mt-3 text-char-800/80 text-[16px]">
        So entsteht ein Werk. Vier Phasen, viele Stunden — jedes Stück durchläuft sie in dieser Reihenfolge.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {process.map(step => (
        <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/30 p-5 md:p-6">
          <div class="font-display font-extrabold text-ember-700 text-[36px] leading-none">{step.num}</div>
          <h3 class="mt-2 font-display font-bold text-char-900 text-[18px]">{step.title}</h3>
          <p class="mt-2 text-[14px] text-char-800/80 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- Materials -->
    <div class="mt-10 grid md:grid-cols-2 gap-5">
      <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/30 p-5 md:p-6">
        <h3 class="font-display font-bold text-char-900 text-[17px]">Material</h3>
        <p class="mt-1 text-[13px] text-ember-700 font-semibold uppercase tracking-wider">Holz aus regionaler Forstwirtschaft</p>
        <p class="mt-2 text-[14px] text-char-800/80 leading-relaxed">
          Birke für Feinheit, Eiche für Tiefe, Linde für weiche Übergänge. Jedes Stück Holz wird vor Bearbeitung mindestens 12 Monate gelagert.
        </p>
      </div>
      <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/30 p-5 md:p-6">
        <h3 class="font-display font-bold text-char-900 text-[17px]">Werkzeug</h3>
        <p class="mt-1 text-[13px] text-ember-700 font-semibold uppercase tracking-wider">Brennkolben mit auswechselbarer Spitze</p>
        <p class="mt-2 text-[14px] text-char-800/80 leading-relaxed">
          14 Spitzen, von Haarlinie bis Schraffur. Temperaturen zwischen 380 °C und 750 °C — jede Holzart braucht ihre eigene Hitze.
        </p>
      </div>
    </div>
  </div>

  <!-- Milestones -->
  <div class="wood-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-400/40 mb-10">
    <div class="mb-10">
      <p class="eyebrow">Bisher</p>
      <h2 class="mt-3 font-display font-extrabold text-char-900 text-[28px] md:text-[38px] leading-tight">Stationen</h2>
    </div>

    <div class="relative">
      <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-ember-500 via-ember-600/40 to-transparent hidden md:block"></div>
      <div class="space-y-6 md:space-y-8 md:pl-14">
        {milestones.map(m => (
          <div class="relative">
            <div class="hidden md:block absolute -left-[46px] top-1 w-4 h-4 rounded-full bg-ember-500 ring-2 ring-wood-200 shadow-[0_0_12px_rgba(232,93,4,.5)]"></div>
            <span class="text-ember-700 font-bold text-[13px] uppercase tracking-widest">{m.year}</span>
            <h3 class="mt-0.5 font-display font-bold text-char-900 text-[18px] md:text-[20px]">{m.title}</h3>
            <p class="text-[14px] text-char-800/70">{m.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Contact CTA -->
  <div class="cream-panel rounded-[28px] px-6 md:px-12 py-12 md:py-14 ring-1 ring-wood-300/60 text-center">
    <p class="eyebrow">Zusammenarbeit</p>
    <h2 class="mt-3 font-display font-extrabold text-char-900 text-[28px] md:text-[38px] leading-tight">
      Sehen wir uns in der Werkstatt?
    </h2>
    <p class="mt-3 text-char-800/80 max-w-md mx-auto text-[16px]">
      Auftragsarbeiten, Studio-Besuche und Presseanfragen sind herzlich willkommen.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/kontakt" class="btn btn-orange">Kontakt aufnehmen</a>
      <a href="/galerie" class="arrow-link">Werke ansehen</a>
    </div>
  </div>

</div>

</BaseLayout>
