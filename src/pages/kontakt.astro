---
import BaseLayout from '../layouts/BaseLayout.astro';

const faq = [
  {
    q: 'Wie lange dauert eine Auftragsarbeit?',
    a: 'Je nach Größe und Komplexität 4–8 Wochen ab Skizzenfreigabe. Bei Lagerstücken sofortiger Versand.',
  },
  {
    q: 'Liefert ihr international?',
    a: 'Ja, weltweit per DHL versichert. Versandkosten werden im Checkout berechnet.',
  },
  {
    q: 'Kann ich die Werkstatt besuchen?',
    a: 'Sehr gerne — nach Terminvereinbarung. Schreib mir kurz und wir finden einen Slot.',
  },
  {
    q: 'Welche Holzarten verwendest du?',
    a: 'Hauptsächlich Birke, Eiche und Linde aus regionaler Forstwirtschaft. Auf Wunsch auch andere Hölzer.',
  },
  {
    q: 'Wie pflege ich ein Werk?',
    a: 'Trocken halten, nicht in direktes Sonnenlicht. Bei Bedarf 1× jährlich mit Naturöl nachpflegen — Öl liegt jedem Stück bei.',
  },
];
---

<BaseLayout
  title="Kontakt — Alita Ember Pyrography"
  description="Auftragsarbeit, Atelier-Besuch oder Presseanfrage — Alita antwortet innerhalb von 2 Werktagen."
  activeNav="kontakt"
>

<div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-24 md:pb-32">

  <!-- Header -->
  <div class="text-center mb-12 md:mb-16">
    <p class="eyebrow">Kontakt</p>
    <h1 class="mt-3 font-display font-extrabold text-char-900 text-[40px] sm:text-[52px] md:text-[60px] leading-tight">
      Sag Hallo.
    </h1>
    <p class="mt-4 text-char-800/80 max-w-xl mx-auto text-[16px] md:text-[17px]">
      Auftragsarbeit, Atelier-Besuch oder Presseanfrage — ich antworte innerhalb von 2 Werktagen.
    </p>
  </div>

  <!-- Contact info + Form -->
  <div class="grid md:grid-cols-2 gap-6 mb-10">

    <!-- Info -->
    <div class="wood-panel rounded-[28px] px-6 md:px-10 py-10 ring-1 ring-wood-400/40 space-y-7">
      <div>
        <p class="eyebrow mb-2">E-Mail</p>
        <a href="mailto:hallo@alita-ember.de" class="font-display font-bold text-char-900 text-[18px] md:text-[20px] hover:text-ember-700 transition-colors">
          hallo@alita-ember.de
        </a>
        <p class="mt-1 text-[13px] text-char-800/60">Antwortzeit ~ 2 Werktage</p>
      </div>
      <div class="section-divider"></div>
      <div>
        <p class="eyebrow mb-2">Werkstatt</p>
        <p class="font-medium text-char-900">Am Waldrand, Süddeutschland</p>
        <p class="mt-1 text-[13px] text-char-800/60">Besuche nur nach Terminvereinbarung.</p>
        <p class="mt-1 text-[13px] text-char-800/60">Mo–Fr · Werkstattzeiten in der Brennphase begrenzt.</p>
      </div>
      <div class="section-divider"></div>
      <div>
        <p class="eyebrow mb-2">Social</p>
        <div class="flex gap-4">
          <a href="#" aria-label="Instagram" class="arrow-link text-[14px]">Instagram</a>
          <a href="#" aria-label="Pinterest" class="arrow-link text-[14px]">Pinterest</a>
        </div>
      </div>
    </div>

    <!-- Form -->
    <div id="auftrag" class="cream-panel rounded-[28px] px-6 md:px-10 py-10 ring-1 ring-wood-300/60">
      <h2 class="font-display font-bold text-char-900 text-[22px] mb-6">Nachricht senden</h2>
      <form
        class="grid gap-4"
        onsubmit="event.preventDefault(); this.querySelector('button[type=submit]').textContent='Danke — ich melde mich!'; this.reset();"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <input required type="text"  placeholder="Dein Name"    class="field" />
          <input required type="email" placeholder="Deine E-Mail" class="field" />
        </div>
        <select class="field">
          <option value="">Worum geht's?</option>
          <option value="auftrag">Auftragsarbeit</option>
          <option value="shop">Shop-Frage</option>
          <option value="atelier">Atelier-Besuch</option>
          <option value="presse">Presse</option>
          <option value="sonstiges">Sonstiges</option>
        </select>
        <select class="field">
          <option value="">Budget (optional)</option>
          <option value="unclear">Noch unklar</option>
          <option value="under250">unter 250 €</option>
          <option value="250-500">250–500 €</option>
          <option value="500-1000">500–1.000 €</option>
          <option value="1000+">über 1.000 €</option>
        </select>
        <textarea
          required
          rows="4"
          placeholder="Erzähl mir kurz von deiner Idee, Größe, gewünschtem Lieferzeitpunkt …"
          class="field"
        ></textarea>
        <label class="flex items-start gap-3 text-[13px] text-char-800/80 cursor-pointer">
          <input type="checkbox" required class="mt-0.5 accent-ember-600" />
          <span>Ich habe die <a href="#" class="text-ember-700 hover:underline">Datenschutzhinweise</a> gelesen und stimme zu.</span>
        </label>
        <button type="submit" class="btn btn-orange justify-self-start">Nachricht senden</button>
      </form>
    </div>
  </div>

  <!-- FAQ -->
  <div class="cream-panel rounded-[28px] px-6 md:px-12 py-12 md:py-14 ring-1 ring-wood-300/60">
    <div class="mb-8">
      <p class="eyebrow">FAQ</p>
      <h2 class="mt-2 font-display font-bold text-char-900 text-[26px] md:text-[32px]">Häufige Fragen</h2>
    </div>
    <div class="space-y-3 max-w-2xl">
      {faq.map(item => (
        <details class="faq">
          <summary>
            {item.q}
            <svg class="shrink-0 text-ember-600" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </div>

</div>

</BaseLayout>
