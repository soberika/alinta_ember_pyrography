---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { langFromUrl, localizedSingleton, PATHS, UI } from '../lib/i18n';

// Sprache aus der Route (EN-Wrapper: src/pages/en/contact.astro)
const lang = langFromUrl(Astro.url);
const t = UI[lang];
const P = PATHS[lang];

const contact = localizedSingleton(await getCollection('contact'), lang).data;

// Formular-Backend: FormSubmit leitet POSTs als E-Mail weiter (kein Account nötig).
// ⚠️ Beim allerersten Absenden schickt FormSubmit eine Aktivierungs-Mail an diese
// Adresse — den Bestätigungslink einmal anklicken, danach kommen Anfragen direkt an.
const FORM_ENDPOINT = 'https://formsubmit.co/admin@alinta-ember.com';
const FORM_REDIRECT = new URL(`${P.kontakt}/?gesendet=1#auftrag`, Astro.site ?? 'https://www.alinta-ember.com').toString();
---

<Base title={t.meta.kontaktTitle} description={t.meta.kontaktDesc}>
  <Header active="kontakt" />

  <!-- INTRO -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-6 md:pt-8">
      <div class="wood-bg relative rounded-[28px] overflow-hidden ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.45)] px-6 md:px-12 lg:px-16 py-14 md:py-20">
        <div id="embers" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
        <div class="relative max-w-3xl">
          <p class="eyebrow">{contact.heroEyebrow}</p>
          <h1 class="mt-3 font-display font-extrabold text-char-900 leading-[1] text-[44px] sm:text-[64px] md:text-[80px]">{contact.heroTitle}</h1>
          <p class="mt-5 text-[18px] md:text-[20px] text-char-800/90 leading-relaxed max-w-xl">
            {contact.heroIntro}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAKT-CARDS + FORM -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-12 md:pb-16 grid md:grid-cols-12 gap-6">

      <aside class="md:col-span-5 space-y-4">
        <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/40 p-6">
          <div class="eyebrow">{t.contact.email}</div>
          <a href={`mailto:${contact.email}`} class="mt-2 block font-display font-bold text-char-900 text-xl break-all hover:text-ember-700">{contact.email}</a>
        </div>
        {contact.addressLines.length > 0 && (
          <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/40 p-6">
            <div class="eyebrow">{t.contact.workshop}</div>
            <p class="mt-2 font-medium text-char-900">
              {contact.addressLines.map((line, i) => (
                <Fragment>{i > 0 && <br />}{line}</Fragment>
              ))}
            </p>
            {contact.addressNote && <p class="mt-2 text-sm text-char-800/75">{contact.addressNote}</p>}
          </div>
        )}
        <div class="rounded-2xl bg-white/55 ring-1 ring-wood-400/40 p-6">
          <div class="eyebrow">{t.contact.social}</div>
          <div class="mt-3 flex flex-wrap gap-2">
            {contact.socials.map((s) => (
              <a href={s.url} class="btn btn-ghost !py-2 !px-4 !text-sm">{s.label}</a>
            ))}
          </div>
        </div>
        <div class="rounded-2xl wood-panel ring-1 ring-wood-400/40 p-6">
          <div class="eyebrow">{t.contact.responseTime}</div>
          <p class="mt-2 font-display font-bold text-char-900 text-2xl">{contact.responseTime}</p>
          <p class="mt-1 text-sm text-char-800/75">{contact.responseNote}</p>
        </div>
      </aside>

      <div class="md:col-span-7">
        <div id="auftrag" class="cream-panel rounded-[28px] ring-1 ring-wood-300/60 p-7 md:p-10">
          <p class="eyebrow">{t.contact.sendMessage}</p>
          <h2 class="mt-2 font-display font-extrabold text-char-900 text-[28px] md:text-[36px] leading-tight">{contact.formHeading}</h2>
          <p id="werk-bezug" class="hidden mt-3 w-fit items-center gap-2 rounded-full bg-ember-500/10 text-ember-700 border border-ember-500/30 px-4 py-1.5 text-sm font-semibold"></p>

          <form class="mt-6 grid gap-4" action={FORM_ENDPOINT} method="POST">
            <!-- FormSubmit-Steuerfelder: Betreff, Tabellen-Layout der Mail, Spam-Honeypot,
                 Captcha aus (Honeypot reicht), Weiterleitung zurück auf diese Seite -->
            <input type="hidden" name="_subject" value={t.contact.formSubject} />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value={FORM_REDIRECT} />
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="grid sm:grid-cols-2 gap-4">
              <label class="block"><span class="text-sm font-semibold text-char-800/85">{t.contact.formName}</span>
                <input required type="text" name="name" class="field mt-1" placeholder={t.contact.formNamePlaceholder} /></label>
              <label class="block"><span class="text-sm font-semibold text-char-800/85">{t.contact.formEmail}</span>
                <input required type="email" name="email" class="field mt-1" placeholder={t.contact.formEmailPlaceholder} /></label>
            </div>

            <fieldset>
              <legend class="text-sm font-semibold text-char-800/85 mb-2">{t.contact.topic}</legend>
              <div class="flex flex-wrap gap-2">
                <label class="topic"><input type="radio" name="topic" value="auftrag" checked /> <span>{t.contact.topicCommission}</span></label>
                <label class="topic"><input type="radio" name="topic" value="shop" /> <span>{t.contact.topicShop}</span></label>
                <label class="topic"><input type="radio" name="topic" value="atelier" /> <span>{t.contact.topicStudio}</span></label>
                <label class="topic"><input type="radio" name="topic" value="presse" /> <span>{t.contact.topicPress}</span></label>
                <label class="topic"><input type="radio" name="topic" value="sonstiges" /> <span>{t.contact.topicOther}</span></label>
              </div>
            </fieldset>

            <label class="block">
              <span class="text-sm font-semibold text-char-800/85">{t.contact.budget}</span>
              <select name="budget" class="field mt-1">
                <option>{t.contact.budgetUnclear}</option>
                <option>{t.contact.budgetUnder250}</option>
                <option>{t.contact.budget250to500}</option>
                <option>{t.contact.budget500to1000}</option>
                <option>{t.contact.budgetOver1000}</option>
              </select>
            </label>

            <label class="block">
              <span class="text-sm font-semibold text-char-800/85">{t.contact.message}</span>
              <textarea required rows="5" id="contact-message" name="nachricht" class="field mt-1" placeholder={t.contact.messagePlaceholder}></textarea>
            </label>

            <label class="flex items-start gap-3 text-sm text-char-800/85">
              <input type="checkbox" name="datenschutz" value="zugestimmt" class="mt-1" required />
              <span>{t.contact.privacyPre} <a href={P.datenschutz} target="_blank" rel="noopener" class="underline">{t.contact.privacyLink}</a> {t.contact.privacyPost}</span>
            </label>

            <div class="flex flex-wrap gap-3 items-center">
              <button class="btn btn-orange">{t.contact.send}</button>
              <span id="thanks" class="hidden text-sm text-ember-700 font-semibold">{t.contact.thanks}</span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative">
    <div class="max-w-3xl mx-auto px-5 md:px-8 pb-24 md:pb-32">
      <p class="eyebrow text-center">{t.contact.faq}</p>
      <h2 class="mt-2 text-center font-display font-extrabold text-char-900 text-[28px] md:text-[36px]">{t.contact.faqHeading}</h2>
      <div class="mt-8 space-y-3">
        {contact.faq.map((item) => (
          <details class="faq"><summary>{item.question}</summary><p>{item.answer}</p></details>
        ))}
      </div>
    </div>
  </section>

  <Footer />

  <!-- Vorbelegung bei Anfrage zu einem konkreten Werk (?werk=…) aus dem Galerie-/Featured-Modal
       + Erfolgsmeldung nach dem Absenden (?gesendet=1, Redirect von FormSubmit) -->
  <script define:vars={{ MSG: { werkMessage: t.contact.werkMessage, werkRef: t.contact.werkRef } }}>
    (function () {
      const params = new URLSearchParams(location.search);
      if (params.get('gesendet')) {
        const thanks = document.getElementById('thanks');
        if (thanks) thanks.classList.remove('hidden');
      }
      const werk = params.get('werk');
      if (!werk) return;
      const auftrag = document.querySelector('input[name="topic"][value="auftrag"]');
      if (auftrag) auftrag.checked = true;
      const msg = document.getElementById('contact-message');
      if (msg && !msg.value) {
        msg.value = MSG.werkMessage.replace('{werk}', werk);
      }
      const bezug = document.getElementById('werk-bezug');
      if (bezug) {
        bezug.textContent = MSG.werkRef.replace('{werk}', werk);
        bezug.classList.remove('hidden');
        bezug.classList.add('inline-flex');
      }
    })();
  </script>

  <style is:global>
    .topic{ display:inline-flex; align-items:center; gap:.4rem; padding:.5rem .9rem; border-radius:9999px;
      border:1px solid rgba(184,138,85,.5); background:rgba(255,255,255,.55);
      font-size:14px; font-weight:600; color:#5a3f2c; cursor:pointer; transition: all .25s ease; }
    .topic:hover{ color:#e85d04; border-color:#e85d04; }
    .topic input{ accent-color:#e85d04; }
    .topic:has(input:checked){
      color:#fff; background:linear-gradient(180deg,#ff7a1a,#e85d04); border-color:transparent;
      box-shadow:0 6px 18px -6px rgba(232,93,4,.6);
    }
    .topic:has(input:checked) input{ filter:brightness(0) invert(1); }

    details.faq{ border:1px solid rgba(184,138,85,.45); background:rgba(255,255,255,.55); border-radius:18px; padding:1rem 1.25rem; transition: box-shadow .25s ease; }
    details.faq[open]{ box-shadow: 0 12px 30px -16px rgba(232,93,4,.4); border-color:rgba(232,93,4,.4); }
    details.faq summary{ list-style:none; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:1rem; font-weight:700; color:#2a1d14; }
    details.faq summary::-webkit-details-marker{ display:none; }
    details.faq summary::after{ content:'+'; font-weight:800; color:#e85d04; font-size:1.4rem; line-height:1; transition: transform .25s ease; }
    details.faq[open] summary::after{ transform: rotate(45deg); }
    details.faq p{ margin-top:.6rem; color:rgba(61,43,31,.85); line-height:1.55; }
  </style>
</Base>
