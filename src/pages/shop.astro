---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');

// Sort: available first, then by price ascending
const sorted = products
  .map(p => p.data)
  .sort((a, b) => {
    if (a.available !== b.available) return a.available ? -1 : 1;
    return a.price - b.price;
  });
---

<BaseLayout
  title="Shop — Alita Ember Pyrography"
  description="Handgebrannte Pyrography-Originale, limitierte Editionen und Fine Art Prints. Jedes Werk signiert und datiert."
  activeNav="shop"
>

<!--
  ╔══════════════════════════════════════════════════════╗
  ║  SNIPCART INTEGRATION — AKTIVIERUNG                 ║
  ║                                                      ║
  ║  1. Erstelle ein Konto auf https://snipcart.com     ║
  ║  2. Ersetze YOUR_PUBLIC_API_KEY unten mit deinem    ║
  ║     echten Public API Key aus dem Snipcart Dashboard ║
  ║  3. Entferne die Kommentare um die beiden Script-    ║
  ║     und Link-Tags                                    ║
  ║  4. Die "snipcart-add-item"-Buttons funktionieren   ║
  ║     dann automatisch                                 ║
  ║                                                      ║
  ║  Alle Produkt-Daten sind in                         ║
  ║  src/content/products/*.json editierbar             ║
  ╚══════════════════════════════════════════════════════╝
-->

<!--
<link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.4/default/snipcart.css" />
<script async src="https://cdn.snipcart.com/themes/v3.7.4/default/snipcart.js"></script>
<div hidden id="snipcart" data-api-key="YOUR_PUBLIC_API_KEY" data-currency="eur"></div>
-->

<div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-24 md:pb-32">

  <!-- Header -->
  <div class="text-center mb-12 md:mb-16">
    <p class="eyebrow">Shop · Originale & Editionen</p>
    <h1 class="mt-3 font-display font-extrabold text-char-900 text-[40px] sm:text-[52px] md:text-[64px] leading-tight">
      Handgebrannte<br class="hidden sm:block" /> Unikate
    </h1>
    <p class="mt-4 text-char-800/80 max-w-2xl mx-auto text-[16px] md:text-[17px]">
      Jedes Werk handgebrannt, signiert und in liebevoller Verpackung versendet. Versand innerhalb 5–7 Werktagen aus Deutschland.
    </p>
  </div>

  <!-- Product grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
    {sorted.map(product => (
      <div id={product.id} class="cream-panel rounded-[24px] ring-1 ring-wood-300/60 overflow-hidden group transition-transform duration-300 hover:-translate-y-1">
        <div class="aspect-[4/3] overflow-hidden bg-wood-200">
          <img
            src={product.img}
            alt={product.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
            loading="lazy"
          />
        </div>
        <div class="p-5 md:p-6">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="font-display font-bold text-char-900 text-[18px] md:text-[20px] leading-snug">
                {product.title}
              </h2>
              {product.size && (
                <p class="mt-0.5 text-[13px] text-char-800/60">{product.size} · {product.material}</p>
              )}
            </div>
            <div class="text-right shrink-0">
              <span class="font-display font-extrabold text-char-900 text-[22px] md:text-[24px]">
                {product.id === 'custom-commission' ? 'ab ' : ''}{product.price} €
              </span>
              <p class="text-[11px] text-char-800/55">inkl. MwSt.</p>
            </div>
          </div>

          <p class="mt-3 text-[14px] md:text-[15px] text-char-800/80 leading-relaxed">
            {product.desc}
          </p>

          {product.edition && (
            <p class="mt-3 text-[12px] font-semibold text-ember-700 uppercase tracking-widest">
              {product.edition}
            </p>
          )}

          <div class="mt-5 flex gap-3">
            {product.available ? (
              product.id === 'custom-commission' ? (
                <a href="/kontakt#auftrag" class="btn btn-orange flex-1 text-center">
                  Anfrage starten
                </a>
              ) : (
                <button
                  class="btn btn-orange flex-1 snipcart-add-item"
                  data-item-id={product.id}
                  data-item-price={product.price}
                  data-item-url={`/shop#${product.id}`}
                  data-item-name={product.title}
                  data-item-image={product.img}
                  data-item-description={product.desc}
                  data-item-max-quantity="1"
                  onclick="this.textContent='Hinzugefügt ✓'; setTimeout(()=>this.textContent='In den Warenkorb',2500);"
                >
                  In den Warenkorb
                </button>
              )
            ) : (
              <button class="btn btn-ghost flex-1 cursor-not-allowed opacity-60" disabled>
                Vergriffen
              </button>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Commission CTA -->
  <div class="mt-16 wood-panel rounded-[28px] px-6 md:px-12 py-12 md:py-16 ring-1 ring-wood-400/40 grid md:grid-cols-2 gap-8 items-center">
    <div>
      <p class="eyebrow">Auftragsarbeit</p>
      <h2 class="mt-3 font-display font-extrabold text-char-900 text-[28px] md:text-[38px] leading-tight">
        Dein Motiv. In Holz gebrannt.
      </h2>
      <p class="mt-4 text-char-800/85 text-[16px] leading-relaxed">
        Erzähl mir, was du dir vorstellst — Tier, Portrait, Hochzeitsbild, Erinnerungsstück. Ich melde mich mit Skizze und Angebot innerhalb von 3 Werktagen.
      </p>
      <div class="mt-8 grid grid-cols-2 gap-3 text-sm text-char-800/80">
        <div class="rounded-xl bg-white/55 ring-1 ring-wood-400/30 p-3">
          <span class="block text-[11px] uppercase tracking-widest text-ember-700 font-semibold">Lieferzeit</span>
          <span class="block mt-0.5 font-medium">4–8 Wochen</span>
        </div>
        <div class="rounded-xl bg-white/55 ring-1 ring-wood-400/30 p-3">
          <span class="block text-[11px] uppercase tracking-widest text-ember-700 font-semibold">Ab</span>
          <span class="block mt-0.5 font-medium">250 €</span>
        </div>
        <div class="rounded-xl bg-white/55 ring-1 ring-wood-400/30 p-3">
          <span class="block text-[11px] uppercase tracking-widest text-ember-700 font-semibold">Größen</span>
          <span class="block mt-0.5 font-medium">nach Absprache</span>
        </div>
        <div class="rounded-xl bg-white/55 ring-1 ring-wood-400/30 p-3">
          <span class="block text-[11px] uppercase tracking-widest text-ember-700 font-semibold">Versand</span>
          <span class="block mt-0.5 font-medium">Weltweit</span>
        </div>
      </div>
    </div>
    <div>
      <a href="/kontakt#auftrag" class="btn btn-orange w-full text-center text-[17px] py-4">
        Anfrage starten
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Shipping & Payment Info -->
  <div class="mt-10 grid md:grid-cols-3 gap-4">
    {[
      {
        title: 'Versand & Verpackung',
        text: 'DHL versichert, plastikfrei verpackt in handbeschriftetem Karton. Versand innerhalb von 5–7 Werktagen nach Bestellung.'
      },
      {
        title: 'Zahlung',
        text: 'PayPal, Klarna, Überweisung. Alle Preise inkl. MwSt. — Kleinunternehmerregelung §19 UStG.'
      },
      {
        title: 'Rückgabe',
        text: '14 Tage Rückgaberecht für Lagerstücke. Auftragsarbeiten sind vom Widerruf ausgenommen.'
      }
    ].map(item => (
      <div class="cream-panel rounded-2xl ring-1 ring-wood-300/60 p-5 md:p-6">
        <h3 class="font-display font-bold text-char-900 text-[17px]">{item.title}</h3>
        <p class="mt-2 text-[14px] text-char-800/80 leading-relaxed">{item.text}</p>
      </div>
    ))}
  </div>

</div>

</BaseLayout>
