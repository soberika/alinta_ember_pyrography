---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkModal from '../components/WorkModal.astro';
import { getCollection } from 'astro:content';

const allWorks = await getCollection('works');

const categories = [
  { key: 'alle',      label: 'Alle' },
  { key: 'tiere',     label: 'Tiere & Mythos' },
  { key: 'natur',     label: 'Natur' },
  { key: 'steampunk', label: 'Steampunk' },
  { key: 'portrait',  label: 'Portrait' },
];
---

<BaseLayout
  title="Galerie — Alita Ember Pyrography"
  description="Alle Pyrography-Werke von Alita Ember — gebrannte Unikate auf Holz. Phönix, Rose, Nebelwald, Steampunk und mehr."
  activeNav="galerie"
>

<div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-24 md:pb-32">

  <!-- Header -->
  <div class="text-center mb-10 md:mb-14">
    <p class="eyebrow">Galerie</p>
    <h1 class="mt-3 font-display font-extrabold text-char-900 text-[40px] sm:text-[52px] md:text-[64px] leading-tight">
      Alle Werke
    </h1>
    <p class="mt-4 text-char-800/80 max-w-xl mx-auto text-[16px] md:text-[17px]">
      Eine Sammlung gebrannter Stücke aus den letzten Jahren — sortiert nach Kategorie. Klicke ein Werk an, um Details zu sehen.
    </p>
  </div>

  <!-- Filter chips -->
  <div id="filter" class="flex flex-wrap gap-3 justify-center mb-10 md:mb-12">
    {categories.map(cat => (
      <button
        class={`filter-chip${cat.key === 'alle' ? ' active' : ''}`}
        data-filter={cat.key}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <!-- Works grid -->
  <div id="works-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 md:gap-6">
    {allWorks.map(work => (
      <button
        class="work-card group relative text-left focus:outline-none focus:ring-2 focus:ring-ember-500/60 rounded-2xl"
        data-id={work.data.id}
        data-category={work.data.category}
        aria-label={`${work.data.title} Details öffnen`}
      >
        <span class="work-card-glow"></span>
        <div class="work-card-frame p-3 md:p-4">
          <div class="aspect-[3/4] overflow-hidden rounded-xl bg-wood-300">
            <img
              src={work.data.img}
              alt={work.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
              loading="lazy"
            />
          </div>
          <div class="mt-3 md:mt-4 flex items-center justify-between">
            <span class="font-display font-bold text-char-900 text-[17px] md:text-[19px]">{work.data.title}</span>
            <span class="text-ember-700 text-sm font-semibold flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
          <span class="block mt-1 text-[12px] text-char-800/60 font-medium">{work.data.eyebrow}</span>
        </div>
      </button>
    ))}
  </div>

  <!-- Empty state (shown via JS) -->
  <p id="empty-state" class="hidden text-center text-char-800/70 py-16 text-[17px]">
    Keine Werke in dieser Kategorie. Schau bald wieder vorbei — die Werkstatt brennt täglich.
  </p>

  <!-- CTA -->
  <div class="mt-16 cream-panel rounded-[28px] px-6 md:px-12 py-10 md:py-14 text-center ring-1 ring-wood-300/60">
    <p class="eyebrow">Interesse?</p>
    <h2 class="mt-3 font-display font-extrabold text-char-900 text-[28px] md:text-[36px] leading-tight">
      Ein Werk soll dir gehören?
    </h2>
    <p class="mt-3 text-char-800/80 max-w-md mx-auto text-[16px]">
      Originale & Editionen findest du im Shop. Für eigene Motive: Auftragsarbeit.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/shop" class="btn btn-orange">Zum Shop</a>
      <a href="/kontakt#auftrag" class="arrow-link">Auftrag anfragen</a>
    </div>
  </div>
</div>

<WorkModal works={allWorks.map(w => w.data)} />

</BaseLayout>

<script>
// Filter logic
const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip[data-filter]');
const cards = document.querySelectorAll<HTMLButtonElement>('.work-card[data-category]');
const empty = document.getElementById('empty-state');

chips.forEach(chip => {
  chip.addEventListener('click', () => {
    chips.forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    const filter = chip.dataset.filter ?? 'alle';
    let visible = 0;
    cards.forEach(card => {
      const show = filter === 'alle' || card.dataset.category === filter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
  });
});

// Open modal
document.querySelectorAll<HTMLButtonElement>('.work-card[data-id]').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = btn.dataset.id;
    if (id) window.dispatchEvent(new CustomEvent('open-modal', { detail: id }));
  });
});
</script>
