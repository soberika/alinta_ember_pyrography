---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { WORK_CATEGORIES } from '../lib/categories';
import { formatDimensions } from '../lib/works';

// Sortierung: 'order' wirkt als optionaler Pin (kleiner = weiter vorne);
// innerhalb derselben order-Stufe chronologisch, neueste zuerst.
function byPinThenDate(a, b) {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  const da = a.data.date ? a.data.date.getTime() : 0;
  const db = b.data.date ? b.data.date.getTime() : 0;
  return db - da;
}

const works = (await getCollection('works'))
  .filter((w) => (w.data.status ?? 'public') === 'public')
  .sort(byPinThenDate);

// In das Format bringen, das das Client-Skript erwartet
const items = works.map((w) => ({
  id: w.id,
  cat: w.data.category,
  title: w.data.title,
  img: w.data.image,
  eyebrow: w.data.eyebrow ?? '',
  desc: w.data.description ?? '',
  year: w.data.date ? String(w.data.date.getFullYear()) : '',
  dims: formatDimensions(w.data.dimensions),
  tags: (w.data.tags ?? []).filter(Boolean),
  etsy: w.data.etsyUrl ?? '',
  gallery: (w.data.gallery ?? []).map((g) => ({ img: g.image, caption: g.caption ?? '' })),
  meta: (w.data.meta ?? []).map((m) => [m.label, m.value]),
}));

// Alle vorkommenden Tags (alphabetisch, ohne Leereinträge) → Tag-Filter-Buttons
const allTags = [...new Set(works.flatMap((w) => w.data.tags ?? []))]
  .filter(Boolean)
  .sort((a, b) => a.localeCompare(b, 'de'));
---

<Base
  title="Galerie — Alinta Ember"
  description="Alle Brandmalerei-Werke von Alinta Ember: handgebrannte Motive auf Holz und Kork — von Anime-Portraits bis Naturmotiven, filterbar nach Art des Stücks."
>
  <Header active="galerie" />

  <!-- PAGE INTRO -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-6 md:pt-8">
      <div class="wood-bg relative rounded-[28px] overflow-hidden ring-1 ring-wood-400/40 shadow-[0_30px_60px_-30px_rgba(61,43,31,.45)] px-6 md:px-12 lg:px-16 py-14 md:py-20">
        <div id="embers" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
        <div class="relative max-w-3xl">
          <p class="eyebrow">Galerie</p>
          <h1 class="mt-3 font-display font-extrabold text-char-900 leading-[1] text-[44px] sm:text-[64px] md:text-[80px]">Alle Werke</h1>
          <p class="mt-5 text-[18px] md:text-[20px] text-char-800/90 leading-relaxed">
            Eine Sammlung gebrannter Stücke aus den letzten Jahren — die neuesten zuerst, filterbar nach Art des Stücks. Klicke ein Werk an, um Details zu sehen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FILTER + GRID -->
  <section id="filter" class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pt-10 md:pt-14 pb-12 md:pb-16">
      <div class="flex flex-wrap items-center gap-2 md:gap-3 mb-8 md:mb-10" id="filters">
        <button data-cat="all" class="filter-chip active">Alle</button>
        {WORK_CATEGORIES.map((c) => (
          <button data-cat={c.value} class="filter-chip">{c.label}</button>
        ))}
      </div>

      <!-- Tag-Filter: alle vorkommenden Tags als Buttons, klickbar (Toggle) -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 md:gap-3 -mt-3 mb-8 md:mb-10" id="tagfilter">
          <span class="text-[12px] uppercase tracking-[.18em] text-char-800/55 font-semibold mr-1">Tags</span>
          {allTags.map((t) => (
            <button type="button" class="tag-btn" data-tag={t}>#{t}</button>
          ))}
        </div>
      )}

      <div id="works-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 md:gap-6"></div>

      <p id="empty-state" class="hidden text-center text-char-800/70 mt-10">Keine Werke in dieser Auswahl. Schau bald wieder vorbei — die Werkstatt brennt täglich.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative">
    <div class="max-w-6xl mx-auto px-5 md:px-8 pb-24 md:pb-32">
      <div class="cream-panel rounded-[28px] px-6 md:px-12 lg:px-16 py-12 md:py-16 ring-1 ring-wood-300/60 text-center">
        <h2 class="font-display font-extrabold text-char-900 text-[32px] md:text-[44px]">Ein Werk soll dir gehören?</h2>
        <p class="mt-3 text-char-800/80 max-w-xl mx-auto">Originale & Editionen findest du im Shop. Für eigene Motive: Auftragsarbeit.</p>
        <div class="mt-7 flex flex-wrap gap-4 justify-center">
          <a href="/shop" class="btn btn-orange">Zum Shop</a>
          <a href="/kontakt#auftrag" class="btn btn-yellow">Auftrag anfragen</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MODAL -->
  <div id="modal" class="fixed inset-0 z-[60] hidden items-center justify-center px-4">
    <div id="modal-backdrop" class="absolute inset-0 modal-backdrop"></div>
    <div class="relative modal-pop w-full max-w-3xl rounded-3xl overflow-hidden shadow-ember-glow-lg ring-1 ring-ember-500/40 bg-wood-100">
      <button id="modal-close" aria-label="Schließen" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-black/30 hover:bg-black/50 text-white grid place-items-center backdrop-blur">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <div class="grid md:grid-cols-2">
        <div class="bg-wood-200 p-6 md:p-8 flex flex-col items-center justify-center gap-4">
          <div class="relative w-full aspect-[3/4] max-w-[360px]">
            <div class="absolute -inset-4 rounded-3xl blur-2xl opacity-80" style="background: radial-gradient(closest-side, rgba(255,140,30,.45), transparent 70%);"></div>
            <img id="modal-img" alt="" class="relative w-full h-full object-cover rounded-2xl ring-1 ring-wood-400/50" />
          </div>
          <!-- Work-in-Progress-Thumbnails (nur sichtbar, wenn vorhanden) -->
          <div id="modal-thumbs" class="hidden w-full max-w-[360px] flex flex-wrap gap-2 justify-center"></div>
        </div>
        <div class="p-7 md:p-10 wood-panel">
          <p class="eyebrow" id="modal-eyebrow">Werk</p>
          <h3 id="modal-title" class="mt-2 font-display font-extrabold text-char-900 text-3xl md:text-4xl leading-tight">Titel</h3>
          <p id="modal-desc" class="mt-4 text-char-800/90 text-[16px] leading-relaxed whitespace-pre-line"></p>
          <ul id="modal-meta" class="mt-6 grid grid-cols-2 gap-3 text-[14px] text-char-800/80"></ul>
          <div id="modal-tags" class="mt-5 flex flex-wrap gap-2"></div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a id="modal-etsy-link" href="#" target="_blank" rel="noopener" class="btn btn-yellow hidden">Auf Etsy kaufen ↗</a>
            <a id="modal-commission-link" href="/kontakt#auftrag" class="btn btn-orange">Neuauflage anfragen</a>
            <button id="modal-close-2" class="btn btn-yellow">Schließen</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style is:global>
    .filter-chip{
      display:inline-flex; align-items:center;
      padding:.55rem 1rem; border-radius:9999px;
      font-weight:600; font-size:14px;
      color:#5a3f2c; background:rgba(255,255,255,.55);
      border:1px solid rgba(184,138,85,.5);
      transition: all .25s ease; cursor:pointer;
    }
    .filter-chip:hover{ color:#e85d04; border-color:#e85d04; }
    .filter-chip.active{
      color:#fff;
      background:linear-gradient(180deg,#ff7a1a 0%, #e85d04 100%);
      border-color:transparent;
      box-shadow: 0 6px 18px -6px rgba(232,93,4,.6);
    }
    .modal-thumb{
      width:56px; height:56px; flex:0 0 auto;
      border-radius:.6rem; overflow:hidden; cursor:pointer;
      border:2px solid rgba(184,138,85,.5);
      transition: border-color .2s ease, transform .2s ease;
    }
    .modal-thumb img{ width:100%; height:100%; object-fit:cover; display:block; }
    .modal-thumb:hover{ transform: translateY(-2px); border-color:#e85d04; }
    .modal-thumb.active{ border-color:#e85d04; box-shadow:0 4px 12px -4px rgba(232,93,4,.6); }
  </style>

  <script define:vars={{ ITEMS: items }}>
    const grid = document.getElementById('works-grid');
    const filters = document.getElementById('filters');
    const empty = document.getElementById('empty-state');
    const tagfilter = document.getElementById('tagfilter');
    let active = 'all';
    let activeTag = null;

    function render(){
      const list = ITEMS.filter(i =>
        (active === 'all' || i.cat === active) &&
        (!activeTag || (i.tags || []).includes(activeTag))
      );
      empty.classList.toggle('hidden', list.length > 0);
      grid.innerHTML = list.map(w => `
        <button class="work-card group relative text-left focus:outline-none focus:ring-2 focus:ring-ember-500/60 rounded-2xl h-full flex flex-col" data-id="${w.id}" aria-label="${w.title}">
          <span class="work-card-glow"></span>
          <div class="work-card-frame p-3 md:p-4 h-full flex flex-col">
            <div class="aspect-[3/4] overflow-hidden rounded-xl bg-wood-300">
              <img src="${w.img}" alt="${w.title}" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]" />
            </div>
            <div class="mt-3 md:mt-4 flex-1">
              <div class="font-display font-bold text-char-900 text-[16px] md:text-[18px] leading-tight">${w.title}</div>
              <div class="text-[12px] mt-1 uppercase tracking-[.18em] text-ember-700 font-semibold">${w.eyebrow}</div>
            </div>
          </div>
        </button>
      `).join('');
      grid.querySelectorAll('.work-card').forEach(btn => {
        btn.addEventListener('click', () => openModal(btn.dataset.id));
      });
    }

    // Aktiven Tag-Filter setzen/entfernen (+ in der URL spiegeln, damit teilbar/deeplinkbar)
    function setTag(tag){
      activeTag = tag || null;
      const url = new URL(location.href);
      if (activeTag) url.searchParams.set('tag', activeTag);
      else url.searchParams.delete('tag');
      history.replaceState(null, '', url);
      syncTagButtons();
      render();
    }
    // Aktiven Zustand der Tag-Buttons spiegeln
    function syncTagButtons(){
      if (!tagfilter) return;
      tagfilter.querySelectorAll('.tag-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.tag === activeTag)
      );
    }

    // Klick auf einen Tag-Button: Toggle; Kategorie dabei auf „Alle" zurück
    if (tagfilter) {
      tagfilter.addEventListener('click', (e) => {
        const b = e.target.closest('.tag-btn'); if (!b) return;
        const next = b.dataset.tag === activeTag ? null : b.dataset.tag;
        if (next) {
          active = 'all';
          filters.querySelectorAll('.filter-chip').forEach(c => c.classList.toggle('active', c.dataset.cat === 'all'));
        }
        setTag(next);
      });
    }

    filters.addEventListener('click', (e) => {
      const b = e.target.closest('.filter-chip'); if (!b) return;
      active = b.dataset.cat;
      filters.querySelectorAll('.filter-chip').forEach(c => c.classList.toggle('active', c === b));
      // Kategorie und Tag schließen sich aus → Tag-Filter aufheben (setTag rendert mit)
      setTag(null);
    });

    // Tag aus der URL übernehmen (?tag=…), z. B. wenn von der Startseite verlinkt
    const initialTag = new URLSearchParams(location.search).get('tag');
    if (initialTag) activeTag = initialTag;
    syncTagButtons();
    render();

    // modal
    const modal = document.getElementById('modal');
    const backdrop = document.getElementById('modal-backdrop');
    const mainImg = document.getElementById('modal-img');
    const thumbsEl = document.getElementById('modal-thumbs');
    function openModal(id){
      const w = ITEMS.find(x => x.id === id); if (!w) return;
      mainImg.src = w.img;
      mainImg.alt = w.title;
      document.getElementById('modal-eyebrow').textContent = w.eyebrow;
      document.getElementById('modal-title').textContent = w.title;
      document.getElementById('modal-desc').textContent  = w.desc;
      document.getElementById('modal-commission-link').href =
        '/kontakt?werk=' + encodeURIComponent(w.title) + '#auftrag';
      const etsyLink = document.getElementById('modal-etsy-link');
      etsyLink.href = w.etsy || '#';
      etsyLink.classList.toggle('hidden', !w.etsy);
      const tile = (k, v) => `
        <li class="rounded-xl bg-white/55 border border-wood-400/40 px-3 py-2">
          <span class="block text-[11px] uppercase tracking-[.18em] text-ember-700 font-semibold">${k}</span>
          <span class="block mt-0.5 font-medium">${v}</span>
        </li>`;
      const yearTile = w.year ? tile('Jahr', w.year) : '';
      const dimsTile = w.dims ? tile('Maße', w.dims) : '';
      document.getElementById('modal-meta').innerHTML =
        yearTile + dimsTile + w.meta.map(([k,v]) => tile(k, v)).join('');

      const tagsEl = document.getElementById('modal-tags');
      tagsEl.innerHTML = (w.tags || [])
        .map(t => `<button type="button" class="tag-btn" data-tag="${t}" title="Nur Werke mit #${t} zeigen">#${t}</button>`)
        .join('');
      tagsEl.classList.toggle('hidden', !(w.tags && w.tags.length));
      tagsEl.querySelectorAll('[data-tag]').forEach(b => b.addEventListener('click', () => {
        // Tag-Filter setzen, Kategorie zurück auf „Alle", Modal schließen, zum Raster scrollen
        active = 'all';
        filters.querySelectorAll('.filter-chip').forEach(c => c.classList.toggle('active', c.dataset.cat === 'all'));
        setTag(b.dataset.tag);
        closeModal();
        document.getElementById('filter').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }));

      // Work-in-Progress-Galerie: Hauptbild + Zusatzbilder als Thumbnails.
      // Klick auf ein Thumbnail vergrößert es im Hauptbild-Bereich.
      if (w.gallery && w.gallery.length){
        const shots = [{ img: w.img, caption: w.title }, ...w.gallery];
        thumbsEl.innerHTML = shots.map((s, i) => `
          <button type="button" class="modal-thumb${i === 0 ? ' active' : ''}" data-src="${s.img}" title="${s.caption}" aria-label="${s.caption}">
            <img src="${s.img}" alt="${s.caption}" />
          </button>`).join('');
        thumbsEl.querySelectorAll('.modal-thumb').forEach(btn => {
          btn.addEventListener('click', () => {
            mainImg.src = btn.dataset.src;
            thumbsEl.querySelectorAll('.modal-thumb').forEach(b => b.classList.toggle('active', b === btn));
          });
        });
        thumbsEl.classList.remove('hidden');
        thumbsEl.classList.add('flex');
      } else {
        thumbsEl.innerHTML = '';
        thumbsEl.classList.add('hidden');
        thumbsEl.classList.remove('flex');
      }

      modal.classList.remove('hidden'); modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function closeModal(){
      modal.classList.add('hidden'); modal.classList.remove('flex');
      document.body.style.overflow = '';
    }
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-close-2').addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    window.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>
</Base>
